# Copy to .env and adjust. All variables are optional; defaults shown.
# Settings are read with the APP_ prefix (see app/config.py).

# --- Runtime ---
APP_ENV=production
APP_LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000

# --- CORS: comma-separated frontend origins, or * for any ---
APP_CORS_ALLOW_ORIGINS=*
# e.g. APP_CORS_ALLOW_ORIGINS=https://app.example.com,http://localhost:5173

# --- Upload limits (bytes / counts) ---
APP_MAX_UPLOAD_BYTES=536870912     # 512 MiB total per request
APP_MAX_FILE_BYTES=67108864        # 64 MiB per PDF
APP_MAX_FILES_PER_SIDE=20          # max PDFs per folder (reference / candidate)
APP_MAX_PAIRS=20                   # max matched pairs per job

# --- Worker / job store (sized for a small EC2 box) ---
APP_WORKER_CONCURRENCY=1           # CV threads; raise on multi-vCPU hosts
APP_MAX_PENDING_JOBS=8             # queued+running before /compare returns 503
APP_JOB_TTL_SECONDS=3600           # evict finished jobs after this long
APP_MAX_JOBS=50                    # hard cap on retained jobs (memory bound)

# --- Comparator algorithm config (path inside the container) ---
APP_COMPARATOR_CONFIG_PATH=/srv/config.yaml
