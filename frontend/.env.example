# Copy to .env.local for local overrides. All client vars must be prefixed VITE_.

# Base URL for the backend API.
# - Leave empty for same-origin (production behind CloudFront, which routes /api/* to the backend;
#   and local dev, where Vite proxies /api -> VITE_DEV_API_TARGET).
# - Set to an absolute URL (e.g. https://api.example.com) only when the SPA is hosted on a
#   different origin than the API (then also add that SPA origin to the backend's
#   APP_CORS_ALLOW_ORIGINS).
VITE_API_BASE_URL=

# Dev-only: where `vite dev` proxies /api to. Defaults to http://localhost:8000.
VITE_DEV_API_TARGET=http://localhost:8000
